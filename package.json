{
  "name": "agent-session-manage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "sessions": "./dist/cli.js"
  },
  "main": "dist/desktop/main.js",
  "scripts": {
    "build": "npm run build:node && npm run build:renderer",
    "build:node": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "dev": "tsx src/cli.ts",
    "dev:renderer": "vite",
    "dev:desktop": "npm run build:node && npm run build:renderer && electron dist/desktop/main.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:node && node --test dist/**/*.test.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^37.2.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
