{
  "name": "agent-session-manage",
  "version": "0.1.1",
  "description": "Desktop and CLI tool for browsing, converting, exporting, deleting, and resuming Claude Code and Codex sessions.",
  "author": "evilstar9527",
  "private": true,
  "type": "module",
  "bin": {
    "sessions": "./dist/cli.js"
  },
  "main": "dist/desktop/main.js",
  "scripts": {
    "build": "npm run build:node && npm run build:renderer",
    "build:node": "tsc -p tsconfig.json",
    "build:renderer": "vite build",
    "dev": "tsx src/cli.ts",
    "dev:renderer": "vite",
    "dev:desktop": "npm run build:node && npm run build:renderer && electron dist/desktop/main.js",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:node && node --test dist/**/*.test.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "build": {
    "appId": "com.evilstar9527.agent-session-manage",
    "productName": "Agent Session Manage",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^37.2.6",
    "electron-builder": "^26.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
